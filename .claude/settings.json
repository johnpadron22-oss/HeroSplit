{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_FLOW_HOOKS_ENABLED": "true"
  },
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(npm run dev*)",
      "Bash(npm run check*)",
      "Bash(npm run build*)",
      "Bash(npm run db:push*)",
      "Bash(npm install*)",
      "Bash(npm audit*)",
      "Bash(npx playwright*)",
      "Bash(npx --yes serve*)",
      "Bash(node .claude/*)",
      "Bash(node /tmp/herosplit-qa-test*)",
      "Bash(node /tmp/*.mjs)",
      "Bash(pg_ctlcluster*)",
      "Bash(pg_isready*)",
      "Bash(sudo -u postgres psql*)",
      "Bash(curl -s http://localhost*)",
      "Bash(lsof -t -i:5000)",
      "Bash(kill*)",
      "Bash(ls*)",
      "Bash(find . *)",
      "Bash(grep *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" post-edit",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" session-restore",
            "timeout": 15000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" session-end",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
